# Environment Variables Example
# Copy this file to .env.local and fill in your actual values

# SMTP Configuration for Lead Notifications
# Using Gmail: Get app password from https://myaccount.google.com/apppasswords
# Using Other Providers: Check provider documentation for SMTP details
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-character-app-password-here

# Email Configuration
SMTP_FROM=noreply@is2.shivai.co.in

# Lead Notification Recipients
LEAD_NOTIFICATION_TO=Hospitality.is2@shivai.co.in
LEAD_NOTIFICATION_CC=founders@shivai.co.in

# Environment
NODE_ENV=development
